# 🌐 آدرس بک‌اند شما (API)
# تمام درخواست‌ها به این آدرس ارسال می‌شوند
# مثال‌ها:
#   NEXT_PUBLIC_API_URL=http://localhost:8000/api
#   NEXT_PUBLIC_API_URL=https://api.proparking.ir/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api
